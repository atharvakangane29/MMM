# ────────────────────────────────────────────────────────────
#  UTC Channel Attribution Platform — Backend Environment
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to source control.
# ────────────────────────────────────────────────────────────

# ── Databricks Workspace ──────────────────────────────────────
DATABRICKS_HOST=https://adb-XXXXXXXXXXXXXXXXX.XX.azuredatabricks.net
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Databricks SQL Warehouse ──────────────────────────────────
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/XXXXXXXXXXXXXXXX

# ── Databricks Job ID (MMM Attribution Notebook Job) ─────────
DATABRICKS_JOB_ID=123456789

# ── Unity Catalog defaults ────────────────────────────────────
DEFAULT_CATALOG=coe-consultant-catalog
DEFAULT_SCHEMA=results
MASTER_TABLE=channel_attribution_master_test
JOURNEY_SCHEMA=channel_attribution

# ── Auth (JWT) ────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ── App credentials (stored server-side — never sent to browser) ──
# Comma-separated list of email:password:role tuples
# Example: analyst@company.com:S3cur3P@ss:analyst,admin@company.com:Adm1nP@ss:admin
APP_USERS=analyst@utc.com:password123:analyst

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# ── Export ────────────────────────────────────────────────────
# Max scenarios that can be included in a single export
MAX_EXPORT_SCENARIOS=10
